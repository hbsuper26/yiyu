<!DOCTYPE html>
<html lang="zh-CN" x-data="dashboardData()">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>工作台 - 以渔数媒</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        [x-cloak] { display: none !important; }
        .sidebar-link.active {
            background-color: #EFF6FF;
            color: #2563EB;
            border-right: 3px solid #2563EB;
        }
    </style>
</head>
<body class="bg-slate-50 font-sans text-slate-900 h-screen flex overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-slate-200 flex flex-col hidden md:flex transition-all duration-300" :class="{'w-20': collapsed}">
        <div class="h-16 flex items-center justify-center border-b border-slate-100 group">
            <img src="/static/images/logo.png" alt="Logo" class="w-8 h-8 rounded-lg object-cover shadow-sm group-hover:shadow-md transition-shadow duration-300" x-show="!collapsed">
            <span class="font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-violet-600 text-xl ml-2 drop-shadow-sm" x-show="!collapsed">以渔数媒</span>
            <img src="/static/images/logo.png" alt="Logo" class="w-8 h-8 rounded-lg object-cover shadow-sm" x-show="collapsed">
        </div>
        
        <nav class="flex-1 overflow-y-auto py-4">
            <template x-for="item in menuItems" :key="item.id">
                <a href="#" @click.prevent="currentTab = item.id" 
                   class="sidebar-link flex items-center px-6 py-3 text-slate-600 hover:bg-slate-50 hover:text-blue-600 transition-colors mb-1"
                   :class="{'active': currentTab === item.id, 'justify-center': collapsed}">
                    <i :class="item.icon + ' text-lg'"></i>
                    <span class="ml-3 font-medium" x-show="!collapsed" x-text="item.label"></span>
                </a>
            </template>
        </nav>

        <div class="p-4 border-t border-slate-100">
            <button @click="collapsed = !collapsed" class="w-full flex items-center justify-center text-slate-400 hover:text-slate-600 transition-colors">
                <i :class="collapsed ? 'fas fa-chevron-right' : 'fas fa-chevron-left'"></i>
            </button>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col overflow-hidden">
        
        <!-- Top Header -->
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-6 shadow-sm z-10">
            <div class="flex items-center">
                <button class="md:hidden mr-4 text-slate-500 hover:text-slate-700">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="text-lg font-semibold text-slate-800" x-text="menuItems.find(i => i.id === currentTab).label">概览</h1>
            </div>
            
            <div class="flex items-center space-x-4">
                <button class="text-slate-400 hover:text-slate-600 relative">
                    <i class="fas fa-bell"></i>
                    <span class="absolute -top-1 -right-1 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
                <div class="h-8 w-8 bg-slate-200 rounded-full flex items-center justify-center text-slate-500 font-bold border border-slate-300">
                    A
                </div>
                <div class="hidden md:block text-sm text-right">
                    <div class="font-medium text-slate-700">Admin User</div>
                    <div class="text-xs text-slate-400">Company Inc.</div>
                </div>
            </div>
        </header>

        <!-- Content Area -->
        <main class="flex-1 overflow-y-auto p-6 bg-slate-50 relative">
            
            <!-- Dashboard Overview Tab -->
            <div x-show="currentTab === 'overview'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
                <!-- Stats Cards -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-sm font-medium text-slate-500">账户余额 (USD)</p>
                                <h3 class="text-2xl font-bold text-slate-800 mt-1">$12,450.00</h3>
                            </div>
                            <div class="p-2 bg-blue-50 text-blue-600 rounded-lg">
                                <i class="fas fa-wallet"></i>
                            </div>
                        </div>
                        <div class="text-xs text-green-600 flex items-center">
                            <i class="fas fa-arrow-up mr-1"></i>
                            <span>较上周 +12%</span>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-sm font-medium text-slate-500">活跃账户</p>
                                <h3 class="text-2xl font-bold text-slate-800 mt-1">24</h3>
                            </div>
                            <div class="p-2 bg-purple-50 text-purple-600 rounded-lg">
                                <i class="fas fa-users"></i>
                            </div>
                        </div>
                        <div class="text-xs text-slate-400">总账户数: 30</div>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-sm font-medium text-slate-500">今日消耗 (Est.)</p>
                                <h3 class="text-2xl font-bold text-slate-800 mt-1">$845.20</h3>
                            </div>
                            <div class="p-2 bg-orange-50 text-orange-600 rounded-lg">
                                <i class="fas fa-fire"></i>
                            </div>
                        </div>
                        <div class="text-xs text-red-500 flex items-center">
                            <i class="fas fa-arrow-up mr-1"></i>
                            <span>较昨日 +5%</span>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 flex flex-col justify-center items-center text-center cursor-pointer hover:bg-slate-50 transition-colors border-dashed border-2 border-slate-300">
                        <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center mb-2">
                            <i class="fas fa-plus"></i>
                        </div>
                        <span class="text-sm font-medium text-slate-600">申请新账户</span>
                    </div>
                </div>

                <!-- Recent Activities / Charts Placeholder -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-slate-100 p-6">
                        <h3 class="text-lg font-bold text-slate-800 mb-4">近7日消耗趋势</h3>
                        <div class="h-64 flex items-end justify-between space-x-2 px-4">
                            <!-- Fake Bar Chart -->
                            <div class="w-full bg-blue-100 rounded-t hover:bg-blue-200 transition-colors relative group" style="height: 40%">
                                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity">$400</div>
                            </div>
                            <div class="w-full bg-blue-100 rounded-t hover:bg-blue-200 transition-colors" style="height: 60%"></div>
                            <div class="w-full bg-blue-100 rounded-t hover:bg-blue-200 transition-colors" style="height: 45%"></div>
                            <div class="w-full bg-blue-100 rounded-t hover:bg-blue-200 transition-colors" style="height: 70%"></div>
                            <div class="w-full bg-blue-100 rounded-t hover:bg-blue-200 transition-colors" style="height: 55%"></div>
                            <div class="w-full bg-blue-100 rounded-t hover:bg-blue-200 transition-colors" style="height: 80%"></div>
                            <div class="w-full bg-blue-500 rounded-t shadow-lg shadow-blue-500/30" style="height: 65%"></div>
                        </div>
                        <div class="flex justify-between mt-2 text-xs text-slate-400 px-2">
                            <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
                        <h3 class="text-lg font-bold text-slate-800 mb-4">待办事项</h3>
                        <div class="space-y-4">
                            <div class="flex items-start p-3 bg-yellow-50 rounded-lg border border-yellow-100">
                                <i class="fas fa-exclamation-circle text-yellow-600 mt-1 mr-3"></i>
                                <div>
                                    <h4 class="text-sm font-bold text-yellow-800">账户余额不足预警</h4>
                                    <p class="text-xs text-yellow-700 mt-1">Google Ads 账户 (ID: 9921) 余额低于 $100，请及时充值。</p>
                                    <button class="mt-2 text-xs font-bold text-yellow-800 underline">去充值</button>
                                </div>
                            </div>
                            <div class="flex items-start p-3 bg-blue-50 rounded-lg border border-blue-100">
                                <i class="fas fa-info-circle text-blue-600 mt-1 mr-3"></i>
                                <div>
                                    <h4 class="text-sm font-bold text-blue-800">新功能上线</h4>
                                    <p class="text-xs text-blue-700 mt-1">TikTok 自动规则功能现已支持，点击查看文档。</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Accounts List Tab -->
            <div x-show="currentTab === 'accounts'" x-cloak>
                 <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
                    <div class="p-6 border-b border-slate-100 flex justify-between items-center">
                        <h3 class="text-lg font-bold text-slate-800">广告账户列表</h3>
                        <div class="flex space-x-2">
                            <input type="text" placeholder="搜索账户ID/名称..." class="px-3 py-2 border border-slate-200 rounded-lg text-sm outline-none focus:border-blue-500">
                            <button class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm hover:bg-blue-700 transition-colors">
                                <i class="fas fa-plus mr-1"></i> 新建账户
                            </button>
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
                                    <th class="px-6 py-4 font-semibold">平台</th>
                                    <th class="px-6 py-4 font-semibold">账户名称/ID</th>
                                    <th class="px-6 py-4 font-semibold">状态</th>
                                    <th class="px-6 py-4 font-semibold">当前余额</th>
                                    <th class="px-6 py-4 font-semibold">操作</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 text-sm">
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <i class="fab fa-google text-red-500 text-lg"></i>
                                            <span class="font-medium">Google Ads</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="font-medium text-slate-800">US-Search-Campaign</div>
                                        <div class="text-xs text-slate-400">ID: 882-123-4567</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-bold">Active</span>
                                    </td>
                                    <td class="px-6 py-4 font-mono">$1,200.50</td>
                                    <td class="px-6 py-4">
                                        <button class="text-blue-600 hover:text-blue-800 font-medium mr-3">充值</button>
                                        <button class="text-slate-400 hover:text-slate-600">详情</button>
                                    </td>
                                </tr>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <i class="fab fa-facebook text-blue-600 text-lg"></i>
                                            <span class="font-medium">Meta Ads</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="font-medium text-slate-800">EU-Brand-Awareness</div>
                                        <div class="text-xs text-slate-400">ID: 10029384756</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 bg-yellow-100 text-yellow-700 rounded-full text-xs font-bold">Reviewing</span>
                                    </td>
                                    <td class="px-6 py-4 font-mono">$0.00</td>
                                    <td class="px-6 py-4">
                                        <button class="text-slate-300 cursor-not-allowed font-medium mr-3">充值</button>
                                        <button class="text-slate-400 hover:text-slate-600">详情</button>
                                    </td>
                                </tr>
                                 <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <i class="fab fa-tiktok text-black text-lg"></i>
                                            <span class="font-medium">TikTok Ads</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="font-medium text-slate-800">Global-Video-Feed</div>
                                        <div class="text-xs text-slate-400">ID: 772839102</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-bold">Active</span>
                                    </td>
                                    <td class="px-6 py-4 font-mono">$5,432.00</td>
                                    <td class="px-6 py-4">
                                        <button class="text-blue-600 hover:text-blue-800 font-medium mr-3">充值</button>
                                        <button class="text-slate-400 hover:text-slate-600">详情</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                 </div>
            </div>

             <!-- Recharge & Deduction Tab -->
            <div x-show="currentTab === 'recharge'" x-cloak x-data="{ mode: 'recharge' }"> <!-- mode: 'recharge' or 'deduct' -->
                <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-sm border border-slate-100 p-8">
                    
                    <div class="flex justify-center mb-8 bg-slate-100 p-1 rounded-lg">
                        <button @click="mode = 'recharge'" :class="{'bg-white text-blue-600 shadow-sm': mode === 'recharge', 'text-slate-500 hover:text-slate-700': mode !== 'recharge'}" class="flex-1 py-2 rounded-md font-bold text-sm transition-all">账户充值</button>
                        <button @click="mode = 'deduct'" :class="{'bg-white text-red-600 shadow-sm': mode === 'deduct', 'text-slate-500 hover:text-slate-700': mode !== 'deduct'}" class="flex-1 py-2 rounded-md font-bold text-sm transition-all">余额减款/回收</button>
                    </div>

                    <!-- Recharge Mode -->
                    <div x-show="mode === 'recharge'" x-transition:enter="transition ease-out duration-300">
                        <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
                            <i class="fas fa-plus-circle text-blue-500"></i> 向广告账户充值
                        </h2>
                        
                        <div class="space-y-6">
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2">选择账户</label>
                                <select class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 outline-none">
                                    <option>Google Ads - US-Search-Campaign (ID: 882...)</option>
                                    <option>TikTok Ads - Global-Video-Feed (ID: 772...)</option>
                                </select>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2">充值金额 (USD)</label>
                                <div class="grid grid-cols-3 gap-4 mb-3">
                                    <button class="py-2 border border-slate-200 rounded-lg hover:border-blue-500 hover:bg-blue-50 transition-colors font-medium">$100</button>
                                    <button class="py-2 border border-slate-200 rounded-lg hover:border-blue-500 hover:bg-blue-50 transition-colors font-medium">$500</button>
                                    <button class="py-2 border border-blue-500 bg-blue-50 text-blue-700 rounded-lg transition-colors font-medium">$1,000</button>
                                </div>
                                <input type="number" placeholder="自定义金额" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 outline-none">
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2">支付方式</label>
                                <div class="space-y-3">
                                    <label class="flex items-center p-4 border border-blue-500 bg-blue-50 rounded-lg cursor-pointer">
                                        <input type="radio" name="payment" checked class="h-4 w-4 text-blue-600 focus:ring-blue-500">
                                        <span class="ml-3 font-medium text-slate-800">账户余额支付</span>
                                        <span class="ml-auto text-sm text-slate-500">可用: $12,450.00</span>
                                    </label>
                                    <label class="flex items-center p-4 border border-slate-200 rounded-lg cursor-pointer hover:border-blue-300">
                                        <input type="radio" name="payment" class="h-4 w-4 text-blue-600 focus:ring-blue-500">
                                        <span class="ml-3 font-medium text-slate-800">银行转账 / USDT</span>
                                    </label>
                                </div>
                            </div>

                            <div class="pt-4">
                                <button class="w-full py-3 bg-blue-600 text-white rounded-lg font-bold shadow-lg shadow-blue-500/30 hover:bg-blue-700 transition-colors">
                                    确认支付 $1,000
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Deduct Mode -->
                    <div x-show="mode === 'deduct'" x-transition:enter="transition ease-out duration-300" style="display: none;">
                         <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
                            <i class="fas fa-minus-circle text-red-500"></i> 从广告账户减款 (回收余额)
                        </h2>
                        
                        <div class="bg-yellow-50 border border-yellow-100 p-4 rounded-lg mb-6 flex items-start">
                            <i class="fas fa-info-circle text-yellow-600 mt-1 mr-3"></i>
                            <p class="text-sm text-yellow-700">减款申请提交后，系统将自动冻结对应广告账户的预算。款项将在1-3个工作日内退回至您的平台钱包余额。</p>
                        </div>

                        <div class="space-y-6">
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2">选择转出账户</label>
                                <select class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-red-500 outline-none">
                                    <option>TikTok Ads - Global-Video-Feed (余额: $5,432.00)</option>
                                    <option>Google Ads - US-Search-Campaign (余额: $1,200.50)</option>
                                </select>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2">减款金额 (USD)</label>
                                <div class="relative">
                                    <span class="absolute left-4 top-3.5 text-slate-400">$</span>
                                    <input type="number" placeholder="0.00" class="w-full pl-8 pr-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-red-500 outline-none">
                                    <button class="absolute right-3 top-2 text-xs bg-slate-100 hover:bg-slate-200 text-slate-600 px-2 py-1.5 rounded">全部余额</button>
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2">减款原因 (选填)</label>
                                <textarea class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-red-500 outline-none h-24" placeholder="例如：项目结束，预算回收..."></textarea>
                            </div>

                            <div class="pt-4">
                                <button class="w-full py-3 bg-red-600 text-white rounded-lg font-bold shadow-lg shadow-red-500/30 hover:bg-red-700 transition-colors">
                                    提交减款申请
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </main>
    </div>

    <script>
        function dashboardData() {
            return {
                collapsed: false,
                currentTab: 'overview',
                menuItems: [
                    { id: 'overview', label: '总览', icon: 'fas fa-home' },
                    { id: 'accounts', label: '广告账户', icon: 'fas fa-ad' },
                    { id: 'recharge', label: '充值与减款', icon: 'fas fa-wallet' },
                    { id: 'reports', label: '数据报表', icon: 'fas fa-chart-bar' },
                    { id: 'settings', label: '系统设置', icon: 'fas fa-cog' },
                ]
            }
        }
    </script>
</body>
</html>