                    tools: "实用工具",
                    pricing: "产品定价",
                    articles: "行业动态",
                    contact: "联系我们"
                },
                hero: { badge: "以渔视界", title: "行业前沿资讯与", titleHighlight: "深度洞察", subtitle: "获取最新的全球广告开户政策、流量变现玩法以及以渔平台的最新功能发布。" },
                empty: { title: "暂无文章", desc: "目前暂未发布任何内容" },
                card: { readMore: "阅读全文", team: "以渔官方团队" }
            },
            en: {
                title: "Yiyu Insights - Global Ad Account Management",
                nav: {
                    home: "Home",
                    tools: "Tools",
                    pricing: "Pricing",
                    articles: "Insights",
                    contact: "Contact Us"
                },
                hero: { badge: "Yiyu Vision", title: "Industry News & ", titleHighlight: "Deep Insights", subtitle: "Get the latest global ad account policies, traffic monetization strategies, and Yiyu platform feature updates." },
                empty: { title: "No Articles Yet", desc: "No content has been published here currently." },
                card: { readMore: "Read More", team: "Yiyu Official Team" }
            }
        };

        function appData() {
            return {
                lang: localStorage.getItem('yiyu_lang') || 'zh',
                currentFilter: 'all',
                t: translations,
                toggleLang() {
                    this.lang = this.lang === 'zh' ? 'en' : 'zh';
                    localStorage.setItem('yiyu_lang', this.lang);
                }
            }
        }

        async function syncArticleViews() {
            const counters = Array.from(document.querySelectorAll('.article-view-count'));
            const ids = counters.map((counter) => counter.dataset.articleId).filter(Boolean);
            if (!ids.length) return;

            try {
                const response = await fetch(`/api/article-views?ids=${encodeURIComponent(ids.join(','))}`, {
                    cache: 'no-store'
                });
                if (!response.ok) return;
                const payload = await response.json();
                const views = payload.views || {};

                counters.forEach((counter) => {
                    const articleId = counter.dataset.articleId;
                    const baseViews = Number.parseInt(counter.dataset.baseViews || counter.textContent, 10) || 0;
                    const remoteViews = Number.parseInt(views[articleId], 10);
                    if (Number.isInteger(remoteViews) && remoteViews > baseViews) {
                        counter.textContent = remoteViews.toLocaleString();
                    }
                });
            } catch (error) {
                console.debug('Article view sync skipped:', error);
            }
        }

        // Simple entrance animation
        document.addEventListener('DOMContentLoaded', () => {
            syncArticleViews();

            // Set initial state to visible to prevent invisible cards if animation fails
            gsap.set(".article-card", { opacity: 1, y: 0 });
            
            // Then animate from transparent/down
            gsap.from(".article-card", {
                y: 30,
                opacity: 0,
                duration: 0.6,
                stagger: 0.1,
                ease: "power2.out",
                delay: 0.2,
                clearProps: "all" // Remove inline styles after animation completes
            });
        });
    </script>
