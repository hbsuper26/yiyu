<script>
    const translations = {
        zh: {
            title: "文章详情 - 以渔数媒",
            nav: {
                home: "首页",
                pricing: "产品定价",
                articles: "行业动态",
                contact: "联系我们"
            },
            back: "返回动态列表",
            share: "分享这篇文章：",
            reads: "阅读"
        },
        en: {
            title: "Article Detail - Yiyu Digital",
            nav: {
                home: "Home",
                pricing: "Pricing",
                articles: "Insights",
                contact: "Contact Us"
            },
            back: "Back to Insights",
            share: "Share this article:",
            reads: "Reads"
        },
        vi: {
            title: "Chi tiết bài viết - Yiyu Digital",
            nav: {
                home: "Trang chủ",
                pricing: "Bảng giá",
                articles: "Tin tức",
                contact: "Liên hệ"
            },
            back: "Quay lại Tin tức",
            share: "Chia sẻ bài viết này:",
            reads: "Lượt đọc"
        }
    };

    function appData() {
        return {
            lang: localStorage.getItem('yiyu_lang') || 'zh',
            t: translations,
            toggleLang() {
                    if (this.lang === 'zh') this.lang = 'en';
                    else if (this.lang === 'en') this.lang = 'vi';
                    else this.lang = 'zh';
                    localStorage.setItem('yiyu_lang', this.lang);
                }
        }
    }
</script>
</html>