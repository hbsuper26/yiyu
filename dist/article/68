<!DOCTYPE html>
<html lang="zh-CN" x-data="appData()">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title x-text="t[lang].title">文章详情 - 以渔数媒</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        [x-cloak] { display: none !important; }
        .prose img {
            border-radius: 0.75rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            margin-top: 2rem;
            margin-bottom: 2rem;
        }
        .prose h2 {
            color: #0f172a;
            font-weight: 700;
            font-size: 1.5rem;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
        }
        .prose p {
            color: #475569;
            line-height: 1.8;
            margin-bottom: 1.25rem;
            font-size: 1.125rem;
        }
        .prose blockquote {
            border-left: 4px solid #3b82f6;
            padding-left: 1rem;
            color: #334155;
            font-style: italic;
            background: #eff6ff;
            padding: 1rem;
            border-radius: 0 0.5rem 0.5rem 0;
            margin: 2rem 0;
        }
        .gradient-text {
            background: linear-gradient(135deg, #3B82F6 0%, #9333EA 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body class="font-sans antialiased bg-white">

    <!-- Navbar -->
    <nav class="fixed w-full z-50 transition-all duration-300 bg-white/90 backdrop-blur-md border-b border-slate-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20 items-center">
                <a href="/" class="flex-shrink-0 flex items-center gap-3 group">
                    <img src="/static/images/logo.png" alt="Logo" class="w-10 h-10 rounded-lg object-cover shadow-sm group-hover:shadow-md transition-shadow duration-300" onerror="this.src='https://ui-avatars.com/api/?name=YY&background=0D8ABC&color=fff'">
                    <span class="font-extrabold text-2xl tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-violet-600 drop-shadow-sm">以渔数媒</span>
                </a>
                
                <div class="hidden md:flex space-x-8 items-center">
                    <a href="/" class="text-sm font-medium text-slate-600 hover:text-blue-600 transition-colors" x-text="t[lang].nav.home">首页</a>
                    <a href="/articles" class="text-sm font-medium text-blue-600 transition-colors" x-text="t[lang].nav.articles">行业动态</a>
                                        <a href="/tools" class="text-sm font-medium text-slate-600 hover:text-blue-600 transition-colors" x-text="t[lang].nav.tools">实用工具</a>
<a href="/pricing" class="text-sm font-medium text-slate-600 hover:text-blue-600 transition-colors" x-text="t[lang].nav.pricing">产品定价</a>
                    
                    <button @click="toggleLang()" class="flex items-center space-x-1 px-3 py-1.5 rounded-md border border-slate-200 hover:border-blue-400 hover:bg-slate-50 transition-all">
                        <i class="fas fa-globe text-slate-500 text-xs"></i>
                        <span class="text-xs font-bold text-slate-600" x-text="lang === 'zh' ? 'EN' : '中'"></span>
                    </button>
                    
                    <div class="flex items-center gap-3 pl-4 border-l border-slate-200">
                        <a href="https://t.me/yiyiyiads" target="_blank" class="px-5 py-2.5 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-all shadow-md shadow-blue-500/20" x-text="t[lang].nav.contact">联系我们</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Article Content -->
    <main class="pt-32 pb-24">
        <!-- Back Button & Breadcrumb -->
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
            <a href="/articles" class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors group">
                <div class="w-8 h-8 rounded-full border border-slate-200 flex items-center justify-center group-hover:border-blue-500 group-hover:bg-blue-50 transition-all">
                    <i class="fas fa-arrow-left text-xs group-hover:-translate-x-0.5 transition-transform"></i>
                </div>
                <span x-text="t[lang].back">返回动态列表</span>
            </a>
        </div>

        <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Article Header -->
            <header class="mb-10 text-center">
                <div class="mb-6">
                    <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs font-bold rounded-lg uppercase tracking-wider">
                        <span x-show="lang === 'zh'">
                            产品更新
                            
                        </span>
                        <span x-show="lang === 'en'" x-cloak>
                            Updates
                            
                        </span>
                    </span>
                </div>
                <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 leading-tight mb-8">
                    <span x-show="lang === 'zh'">内容更新说明：以渔官网文章将改为更短、更实用、更多样</span>
                    <span x-show="lang === 'en'" x-cloak>Content Update: Yiyu Articles Will Be Shorter, More Practical, and More Varied</span>
                </h1>
                
                <!-- Author Meta -->
                <div class="flex items-center justify-center gap-6 text-sm text-slate-500 border-t border-b border-slate-100 py-4">
                    <div class="flex items-center gap-2">
                        <i class="far fa-calendar-alt"></i>
                        <span>2026-05-20</span>
                    </div>
                    <div class="h-8 w-px bg-slate-200"></div>
                    <div class="flex items-center gap-2">
                        <i class="far fa-eye"></i>
                        <span><span id="article-view-count" data-article-id="68" data-base-views="61">61</span> <span x-text="t[lang].reads">阅读</span></span>
                    </div>
                </div>
            </header>

            <!-- Featured Image -->
            <div class="rounded-2xl overflow-hidden mb-12 shadow-2xl shadow-slate-200/50">
                <img src="https://picsum.photos/seed/yiyu-20260520-content/800/500" alt="Featured Image" class="w-full h-[400px] object-cover">
            </div>

            <!-- Rich Text Body -->
            <div class="prose max-w-none" x-show="lang === 'zh'">
                <h2>为什么要调整</h2>
<p>过去一段时间，官网文章更偏长篇深度稿，信息量足，但阅读成本也高。对很多正在处理投放问题的用户来说，他们更需要快速判断、清单步骤和可直接复制的操作方法。</p>
<h2>接下来会有什么变化</h2>
<p>第一，篇幅会更克制。文章不再为了显得“深”而堆长段落。第二，形式会更多样。除了行业分析，也会出现巡检 SOP、申诉模板、素材复盘表、客户问答和本周观察。第三，内容会更贴近真实运营场景，比如充值延迟、账户异常、素材审核、月底对账这些每天都会发生的问题。</p>
<h2>不会变的部分</h2>
<p>文章仍然会围绕海外广告账户、充值管理、出海投放和企业级运营效率展开。我们不会把内容做成泛泛而谈的营销鸡汤，而是尽量给到具体判断和可执行建议。</p>
<blockquote>
<p>好内容不一定越长越好。能帮用户少走一步弯路，就是更好的官网内容。</p>
</blockquote>
            </div>
            <div class="prose max-w-none" x-show="lang === 'en'" x-cloak>
                <h2>Why Adjust</h2>
<p>Previous website articles leaned toward long-form depth. They had information, but also higher reading cost. Many users need faster judgment, checklists, and directly usable steps.</p>
<h2>What Will Change</h2>
<p>Articles will be more concise. Formats will become more varied, including SOPs, appeal templates, creative review sheets, customer Q&amp;A, and weekly notes. Topics will stay close to real operations: recharge delays, account issues, creative review, and month-end reconciliation.</p>
<h2>What Will Stay</h2>
<p>The focus remains global ad accounts, recharge management, media operations, and enterprise efficiency. The goal is not generic marketing talk, but concrete judgment and practical advice.</p>
            </div>

            <!-- Social Share (Mock) -->
            <div class="mt-12 pt-8 border-t border-slate-100 flex items-center justify-between">
                <div class="text-sm font-medium text-slate-500" x-text="t[lang].share">分享这篇文章：</div>
                <div class="flex gap-3">
                    <button class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-[#1DA1F2] hover:text-white transition-colors">
                        <i class="fab fa-twitter"></i>
                    </button>
                    <button class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-[#0077B5] hover:text-white transition-colors">
                        <i class="fab fa-linkedin-in"></i>
                    </button>
                    <button class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-[#00B489] hover:text-white transition-colors">
                        <i class="fas fa-link"></i>
                    </button>
                </div>
            </div>
        </article>
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 py-12 border-t border-slate-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <p class="text-slate-400 text-sm">
                &copy; 2026 以渔数媒 (YiYu Ads). All rights reserved.
            </p>
        </div>
    </footer>
</body>
<script>
    const translations = {
        zh: {
            title: "文章详情 - 以渔数媒",
            nav: {
                home: "首页",
                tools: "实用工具",
                    pricing: "产品定价",
                articles: "行业动态",
                contact: "联系我们"
            },
            back: "返回动态列表",
            share: "分享这篇文章：",
            reads: "阅读"
        },
        en: {
            title: "Article Detail - Yiyu Digital",
            nav: {
                home: "Home",
                tools: "Tools",
                    pricing: "Pricing",
                articles: "Insights",
                contact: "Contact Us"
            },
            back: "Back to Insights",
            share: "Share this article:",
            reads: "Reads"
        }
    };

    function appData() {
        return {
            lang: localStorage.getItem('yiyu_lang') || 'zh',
            t: translations,
            toggleLang() {
                this.lang = this.lang === 'zh' ? 'en' : 'zh';
                localStorage.setItem('yiyu_lang', this.lang);
            }
        }
    }

    async function incrementArticleView() {
        const counter = document.getElementById('article-view-count');
        if (!counter) return;

        const articleId = counter.dataset.articleId;
        const baseViews = Number.parseInt(counter.dataset.baseViews || counter.textContent, 10) || 0;
        if (!articleId) return;

        try {
            const response = await fetch(`/api/article-view/${encodeURIComponent(articleId)}`, {
                method: 'POST',
                headers: { 'content-type': 'application/json' },
                body: JSON.stringify({ baseViews }),
                cache: 'no-store'
            });
            if (!response.ok) return;
            const payload = await response.json();
            const views = Number.parseInt(payload.views, 10);
            if (Number.isInteger(views) && views > baseViews) {
                counter.textContent = views.toLocaleString();
            }
        } catch (error) {
            console.debug('Article view increment skipped:', error);
        }
    }

    document.addEventListener('DOMContentLoaded', incrementArticleView);
</script>
</html>