                        <span>2026-04-27</span>
                    </div>
                    <div class="h-8 w-px bg-slate-200"></div>
                    <div class="flex items-center gap-2">
                        <i class="far fa-eye"></i>
                        <span>4267 <span x-text="t[lang].reads">阅读</span></span>
                    </div>
