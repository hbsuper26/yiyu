                linear-gradient(145deg, #07111f 0%, #0f172a 44%, #111827 100%) !important;
            isolation: isolate;
        }
        .hero-bg::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: 1;
            pointer-events: none;
            background-image:
                linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
            background-size: 64px 64px;
            mask-image: linear-gradient(to bottom, black 0%, black 66%, transparent 100%);
        }
        .hero-bg::after {
            content: "";
            position: absolute;
            inset: auto 6% 34px 6%;
            height: 1px;
            z-index: 2;
            pointer-events: none;
            background: linear-gradient(90deg, transparent, rgba(125, 211, 252, .45), transparent);
        }
        #heroCanvas { display: none; }
        #giantTextBack, #giantTextFront {
            opacity: .42;
            letter-spacing: -.08em;
        }
        .hero-bg h1 {
            font-size: clamp(3.8rem, 6.8vw, 6.6rem) !important;
        }
        .glass-panel {
            background: linear-gradient(145deg, rgba(15, 23, 42, .76), rgba(15, 23, 42, .42));
            border-color: rgba(255, 255, 255, .12);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.12), 0 28px 90px rgba(2, 6, 23, .42);
        }
        .rounded-3xl,
        .rounded-2xl {
            border-radius: 8px !important;
        }
        .card-hover,
        #features .group,
        #painpoints .grid > div,
        #advantages .relative.z-10,
        section .bg-white,
        section .bg-slate-50 {
            box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
        }
        .card-hover:hover,
        #features .group:hover,
        #painpoints .grid > div:hover {
            transform: translateY(-6px);
            box-shadow: 0 26px 70px rgba(15, 23, 42, 0.14);
        }
        #platforms,
        #features,
        #advantages,
        section.bg-white,
        section.bg-slate-50 {
            position: relative;
            background:
                linear-gradient(180deg, rgba(248, 251, 255, 0.96), rgba(255, 255, 255, 0.98)) !important;
        }
        #platforms::before,
        #features::before,
        #advantages::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 12% 18%, rgba(37, 99, 235, .08), transparent 30%),
                radial-gradient(circle at 88% 12%, rgba(6, 182, 212, .1), transparent 28%);
        }
        #painpoints,
        section.bg-slate-900 {
            background:
                radial-gradient(circle at 12% 10%, rgba(14, 165, 233, .16), transparent 30%),
                radial-gradient(circle at 88% 34%, rgba(16, 185, 129, .1), transparent 26%),
                linear-gradient(180deg, #07111f 0%, #0b1220 100%) !important;
        }
        #features .grid > div {
            min-height: 100%;
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(148, 163, 184, .18) !important;
        }
        #features .grid > div:not(:last-child) {
            background: rgba(255, 255, 255, .78) !important;
            backdrop-filter: blur(18px);
        }
        .animate-marquee span {
            padding: 14px 18px;
            border: 1px solid rgba(148, 163, 184, .2);
            background: rgba(255,255,255,.68);
            border-radius: 999px;
            box-shadow: 0 8px 26px rgba(15, 23, 42, .06);
        }
        @media (max-width: 768px) {
            nav {
                padding: 8px 12px;
            }
            nav > div { border-radius: 18px; }
            .hero-bg {
                min-height: auto;
                padding-top: 116px;
            }
            .hero-bg h1 {
                font-size: clamp(2.8rem, 14vw, 4.6rem);
            }
            .hero-bg p {
                font-size: 1rem;
            }
            .hero-bg .grid-cols-3 {
                grid-template-columns: 1fr;
            }
            nav .flex-shrink-0 span {
                font-size: 1.25rem;
            }
        }
    </style>
