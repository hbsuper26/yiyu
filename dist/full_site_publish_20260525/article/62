<!DOCTYPE html>
<html lang="zh-CN" x-data="appData()">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title x-text="t[lang].title">文章详情 - 以渔数媒</title>
    <script src="https://cdn.tailwindcss.com"></script>
