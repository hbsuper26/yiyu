<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>抖音视频解析 | 以渔数媒</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        ink: '#101828',
                        line: '#e4e7ec',
                        brand: '#0ea5e9',
                        accent: '#f43f5e'
                    },
                    boxShadow: {
                        soft: '0 20px 60px rgba(15, 23, 42, 0.10)'
                    }
                }
            }
        }
    </script>
    <style>
        body {
            min-height: 100vh;
            background:
                linear-gradient(135deg, rgba(14, 165, 233, 0.12), transparent 34%),
                linear-gradient(225deg, rgba(244, 63, 94, 0.10), transparent 36%),
                #f8fafc;
            color: #101828;
        }

        .metric-card {
            min-height: 112px;
        }

        .segment-list {
            max-height: 360px;
        }

        .text-fit {
            overflow-wrap: anywhere;
        }
    </style>
</head>
<body class="font-sans antialiased">
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-line">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-4 min-w-0">
                <a href="/tools" class="w-10 h-10 rounded-lg border border-line bg-white flex items-center justify-center text-slate-600 hover:text-brand transition-colors" title="返回工具库">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <div class="flex items-center gap-3 min-w-0">
                    <img src="/static/images/logo.png" alt="以渔数媒" class="w-9 h-9 rounded-lg object-cover" onerror="this.src='https://ui-avatars.com/api/?name=YY&background=0EA5E9&color=fff'">
                    <div class="min-w-0">
                        <div class="text-sm text-slate-500">实用工具</div>
                        <h1 class="text-lg font-bold text-ink truncate">抖音视频解析</h1>
                    </div>
                </div>
            </div>
            <button id="resetBtn" class="h-10 px-4 rounded-lg border border-line bg-white text-sm font-semibold text-slate-700 hover:border-brand hover:text-brand transition-colors">
                <i class="fa-solid fa-rotate-right mr-2"></i>重置
            </button>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-10">
        <section class="grid grid-cols-1 lg:grid-cols-[420px_1fr] gap-6 items-start">
            <aside class="bg-white border border-line rounded-2xl shadow-soft overflow-hidden">
                <div class="p-6 border-b border-line">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-sky-50 text-sky-700 text-xs font-bold mb-4">
                        <i class="fa-brands fa-tiktok"></i>
                        视频数据 + 口播文字
                    </div>
                    <h2 class="text-2xl font-black tracking-tight text-ink">粘贴链接开始解析</h2>
                    <p class="text-sm text-slate-500 mt-2 leading-6">支持抖音公开视频链接，解析统计数据、互动构成、文案摘要和语音转文字结果。</p>
                </div>

                <div class="p-6 space-y-5">
                    <div>
                        <label for="videoUrl" class="block text-sm font-bold text-slate-700 mb-2">抖音视频地址</label>
                        <textarea id="videoUrl" rows="5" class="w-full rounded-xl border border-line bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none focus:bg-white focus:border-brand focus:ring-4 focus:ring-sky-100 resize-none text-fit" placeholder="可粘贴整段抖音分享文案，系统会自动提取里面的视频链接"></textarea>
                    </div>

                    <button id="parseBtn" class="w-full h-12 rounded-xl bg-ink text-white font-bold hover:bg-slate-800 transition-colors flex items-center justify-center gap-2">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                        <span>开始解析</span>
                    </button>

                    <div id="statusBox" class="hidden rounded-xl border px-4 py-3 text-sm leading-6"></div>

                    <div class="rounded-xl bg-slate-50 border border-line p-4">
                        <div class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-3">第一版解析范围</div>
                        <div class="grid grid-cols-2 gap-2 text-sm text-slate-700">
                            <div><i class="fa-solid fa-check text-emerald-500 mr-2"></i>标题文案</div>
                            <div><i class="fa-solid fa-check text-emerald-500 mr-2"></i>作者昵称</div>
                            <div><i class="fa-solid fa-check text-emerald-500 mr-2"></i>发布时间</div>
                            <div><i class="fa-solid fa-check text-emerald-500 mr-2"></i>视频时长</div>
                            <div><i class="fa-solid fa-check text-emerald-500 mr-2"></i>五项数据</div>
                            <div><i class="fa-solid fa-check text-emerald-500 mr-2"></i>互动构成</div>
                            <div><i class="fa-solid fa-check text-emerald-500 mr-2"></i>文字稿</div>
                            <div><i class="fa-solid fa-check text-emerald-500 mr-2"></i>摘要关键词</div>
                        </div>
                    </div>
                </div>
            </aside>

            <section class="space-y-6">
                <div id="emptyPanel" class="bg-white border border-line rounded-2xl shadow-soft min-h-[520px] flex flex-col items-center justify-center text-center p-8">
                    <div class="w-20 h-20 rounded-2xl bg-slate-100 flex items-center justify-center text-3xl text-slate-400 mb-5">
                        <i class="fa-solid fa-chart-simple"></i>
                    </div>
                    <h2 class="text-xl font-black text-ink">等待解析视频</h2>
                    <p class="text-sm text-slate-500 mt-2 max-w-md leading-6">结果会在这里展示，包含基础信息、播放互动数据、口播文字、摘要和关键词。</p>
                </div>

                <div id="resultPanel" class="hidden space-y-6">
                    <section class="bg-white border border-line rounded-2xl shadow-soft overflow-hidden">
                        <div class="p-5 border-b border-line flex flex-col md:flex-row md:items-center gap-4">
                            <div id="coverWrap" class="w-full md:w-40 aspect-video rounded-xl bg-slate-100 overflow-hidden flex-shrink-0">
                                <img id="coverImg" alt="视频封面" class="w-full h-full object-cover hidden">
                            </div>
                            <div class="min-w-0 flex-1">
                                <div class="flex flex-wrap items-center gap-2 mb-2">
                                    <span class="px-2.5 py-1 rounded-full bg-sky-50 text-sky-700 text-xs font-bold">公开视频</span>
                                    <span id="videoId" class="px-2.5 py-1 rounded-full bg-slate-100 text-slate-500 text-xs font-semibold"></span>
                                </div>
                                <h2 id="videoTitle" class="text-xl font-black text-ink leading-7 text-fit"></h2>
                                <div class="mt-3 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate-500">
                                    <span><i class="fa-solid fa-user mr-1.5"></i><span id="authorName"></span></span>
                                    <span><i class="fa-regular fa-clock mr-1.5"></i><span id="publishedAt"></span></span>
                                    <span><i class="fa-solid fa-stopwatch mr-1.5"></i><span id="duration"></span></span>
                                </div>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <button id="downloadVideoBtn" class="h-10 px-4 rounded-lg bg-ink text-white text-sm font-bold hover:bg-slate-800 transition-colors disabled:opacity-40 disabled:cursor-not-allowed" disabled>
                                        <i class="fa-solid fa-download mr-2"></i>下载视频
                                    </button>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="grid grid-cols-2 xl:grid-cols-5 gap-4">
                        <div class="metric-card bg-white border border-line rounded-2xl p-4">
                            <div class="text-sm text-slate-500">播放量</div>
                            <div id="playCount" class="text-2xl font-black mt-3"></div>
                        </div>
                        <div class="metric-card bg-white border border-line rounded-2xl p-4">
                            <div class="text-sm text-slate-500">点赞数</div>
                            <div id="likeCount" class="text-2xl font-black mt-3"></div>
                        </div>
                        <div class="metric-card bg-white border border-line rounded-2xl p-4">
                            <div class="text-sm text-slate-500">收藏数</div>
                            <div id="favoriteCount" class="text-2xl font-black mt-3"></div>
                        </div>
                        <div class="metric-card bg-white border border-line rounded-2xl p-4">
                            <div class="text-sm text-slate-500">评论数</div>
                            <div id="commentCount" class="text-2xl font-black mt-3"></div>
                        </div>
                        <div class="metric-card bg-white border border-line rounded-2xl p-4">
                            <div class="text-sm text-slate-500">分享数</div>
                            <div id="shareCount" class="text-2xl font-black mt-3"></div>
                        </div>
                    </section>

                    <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
                        <div class="bg-white border border-line rounded-2xl p-5">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-lg font-black text-ink">互动数据分析</h3>
                                <i class="fa-solid fa-chart-pie text-sky-500"></i>
                            </div>
                            <div class="space-y-3" id="interactionList"></div>
                        </div>

                        <div class="bg-white border border-line rounded-2xl p-5">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-lg font-black text-ink">摘要与关键词</h3>
                                <button id="copySummaryBtn" class="h-9 px-3 rounded-lg border border-line text-sm font-semibold text-slate-600 hover:text-brand hover:border-brand transition-colors">
                                    <i class="fa-regular fa-copy mr-1.5"></i>复制
                                </button>
                            </div>
                            <p id="summaryText" class="text-sm text-slate-700 leading-7 text-fit"></p>
                            <div id="keywordList" class="mt-4 flex flex-wrap gap-2"></div>
                        </div>
                    </section>

                    <section class="bg-white border border-line rounded-2xl p-5">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
                            <div>
                                <h3 class="text-lg font-black text-ink">讲话文字稿</h3>
                                <p id="transcriptStatus" class="text-sm text-slate-500 mt-1"></p>
                            </div>
                            <button id="copyTranscriptBtn" class="h-9 px-3 rounded-lg border border-line text-sm font-semibold text-slate-600 hover:text-brand hover:border-brand transition-colors">
                                <i class="fa-regular fa-copy mr-1.5"></i>复制文字稿
                            </button>
                        </div>
                        <div id="transcriptText" class="rounded-xl bg-slate-50 border border-line p-4 text-sm leading-7 text-slate-700 text-fit"></div>
                        <div id="segmentList" class="segment-list mt-4 space-y-2 overflow-y-auto"></div>
                    </section>
                </div>
            </section>
        </section>
    </main>

    <script>
        const videoUrl = document.getElementById('videoUrl');
        const parseBtn = document.getElementById('parseBtn');
        const resetBtn = document.getElementById('resetBtn');
        const statusBox = document.getElementById('statusBox');
        const emptyPanel = document.getElementById('emptyPanel');
        const resultPanel = document.getElementById('resultPanel');
        const copySummaryBtn = document.getElementById('copySummaryBtn');
        const copyTranscriptBtn = document.getElementById('copyTranscriptBtn');
        const downloadVideoBtn = document.getElementById('downloadVideoBtn');

        let latestResult = null;

        function formatNumber(value, emptyText = '0') {
            if (value === null || value === undefined) return emptyText;
            const num = Number(value || 0);
            if (num >= 100000000) return `${(num / 100000000).toFixed(1)}亿`;
            if (num >= 10000) return `${(num / 10000).toFixed(1)}万`;
            return num.toLocaleString('zh-CN');
        }

        function showStatus(type, message) {
            const styles = {
                info: 'border-sky-200 bg-sky-50 text-sky-700',
                error: 'border-rose-200 bg-rose-50 text-rose-700',
                success: 'border-emerald-200 bg-emerald-50 text-emerald-700'
            };
            statusBox.className = `rounded-xl border px-4 py-3 text-sm leading-6 ${styles[type] || styles.info}`;
            statusBox.textContent = message;
            statusBox.classList.remove('hidden');
        }

        function setLoading(isLoading) {
            parseBtn.disabled = isLoading;
            parseBtn.classList.toggle('opacity-70', isLoading);
            parseBtn.innerHTML = isLoading
                ? '<i class="fa-solid fa-spinner fa-spin"></i><span>解析中</span>'
                : '<i class="fa-solid fa-wand-magic-sparkles"></i><span>开始解析</span>';
        }

        function interactionRow(label, count, total) {
            const value = total ? Math.min((Number(count || 0) / total) * 100, 100) : 0;
            const text = total ? `${formatNumber(count)} · ${value.toFixed(1)}%` : '暂无数据';
            return `
                <div>
                    <div class="flex items-center justify-between text-sm mb-2">
                        <span class="font-semibold text-slate-700">${label}</span>
                        <span class="font-bold text-ink">${text}</span>
                    </div>
                    <div class="h-2 rounded-full bg-slate-100 overflow-hidden">
                        <div class="h-full rounded-full bg-gradient-to-r from-sky-500 to-rose-500" style="width:${value}%"></div>
                    </div>
                </div>
            `;
        }

        function renderResult(data) {
            latestResult = data;
            const video = data.video || {};
            const counts = video.counts || {};
            const transcript = data.transcript || {};
            const analysis = data.analysis || {};

            emptyPanel.classList.add('hidden');
            resultPanel.classList.remove('hidden');

            document.getElementById('videoTitle').textContent = video.title || '未获取到视频文案';
            document.getElementById('videoId').textContent = video.id ? `ID ${video.id}` : 'ID 未知';
            document.getElementById('authorName').textContent = (video.author && video.author.nickname) || '未知作者';
            document.getElementById('publishedAt').textContent = video.publishedAt || '发布时间未知';
            document.getElementById('duration').textContent = video.durationSeconds ? `${video.durationSeconds} 秒` : '时长未知';

            const coverImg = document.getElementById('coverImg');
            if (video.cover) {
                coverImg.src = video.cover;
                coverImg.classList.remove('hidden');
            } else {
                coverImg.removeAttribute('src');
                coverImg.classList.add('hidden');
            }

            document.getElementById('playCount').textContent = counts.play ? formatNumber(counts.play) : '未公开';
            document.getElementById('likeCount').textContent = formatNumber(counts.like);
            document.getElementById('favoriteCount').textContent = formatNumber(counts.favorite);
            document.getElementById('commentCount').textContent = formatNumber(counts.comment);
            document.getElementById('shareCount').textContent = formatNumber(counts.share);

            const totalInteraction = Number(counts.like || 0) + Number(counts.favorite || 0) + Number(counts.comment || 0) + Number(counts.share || 0);
            document.getElementById('interactionList').innerHTML = [
                `<div class="rounded-xl bg-slate-50 border border-line p-3">
                    <div class="text-sm text-slate-500">总互动量</div>
                    <div class="text-2xl font-black text-ink mt-2">${formatNumber(totalInteraction)}</div>
                </div>`,
                interactionRow('点赞占比', counts.like, totalInteraction),
                interactionRow('收藏占比', counts.favorite, totalInteraction),
                interactionRow('评论占比', counts.comment, totalInteraction),
                interactionRow('分享占比', counts.share, totalInteraction)
            ].join('');

            downloadVideoBtn.disabled = !video.playUrl;

            document.getElementById('summaryText').textContent = analysis.summary || '暂无摘要';
            document.getElementById('keywordList').innerHTML = (analysis.keywords || []).length
                ? analysis.keywords.map(keyword => `<span class="px-3 py-1 rounded-full bg-slate-100 text-slate-700 text-sm font-semibold">${keyword}</span>`).join('')
                : '<span class="text-sm text-slate-400">暂无关键词</span>';

            const transcriptText = transcript.text || transcript.message || '暂未生成讲话文字。';
            document.getElementById('transcriptStatus').textContent = transcript.message || statusText(transcript.status);
            document.getElementById('transcriptText').textContent = transcriptText;
            document.getElementById('segmentList').innerHTML = renderSegments(transcript.segments || []);
        }

        function statusText(status) {
            const map = {
                ready: '文字稿已生成',
                empty: '未识别到讲话文字',
                not_configured: '语音转文字服务未配置',
                missing_video_url: '缺少视频播放地址',
                failed: '语音转文字失败'
            };
            return map[status] || '等待文字稿';
        }

        function renderSegments(segments) {
            if (!segments.length) return '';
            return segments.map(segment => {
                const start = Number(segment.start || 0).toFixed(1);
                const end = Number(segment.end || 0).toFixed(1);
                const text = segment.text || '';
                return `
                    <div class="grid grid-cols-[96px_1fr] gap-3 rounded-xl border border-line bg-white px-3 py-2 text-sm">
                        <div class="text-slate-400 font-semibold">${start}s-${end}s</div>
                        <div class="text-slate-700 leading-6 text-fit">${text}</div>
                    </div>
                `;
            }).join('');
        }

        async function parseVideo() {
            const url = videoUrl.value.trim();
            if (!url) {
                showStatus('error', '请先粘贴抖音视频地址。');
                return;
            }

            setLoading(true);
            showStatus('info', '正在解析视频，请稍候。');

            try {
                const response = await fetch('/api/tools/douyin-video/parse', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url })
                });
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.message || '解析未完成');
                }
                renderResult(payload.data);
                showStatus('success', '解析完成。');
            } catch (error) {
                showStatus('error', error.message || '解析未完成，请稍后再试。');
            } finally {
                setLoading(false);
            }
        }

        async function copyText(text, successMessage) {
            if (!text) {
                showStatus('error', '当前没有可复制的内容。');
                return;
            }
            await navigator.clipboard.writeText(text);
            showStatus('success', successMessage);
        }

        async function downloadVideo() {
            const video = latestResult && latestResult.video;
            if (!video || !video.playUrl) {
                showStatus('error', '当前没有可下载的视频地址。');
                return;
            }

            const filename = `${(video.title || 'douyin-video').replace(/[\\/:*?"<>|\r\n]+/g, '_').slice(0, 80)}.mp4`;
            try {
                const link = document.createElement('a');
                link.href = video.playUrl;
                link.download = filename;
                link.target = '_blank';
                link.rel = 'noopener';
                document.body.appendChild(link);
                link.click();
                link.remove();
                showStatus('success', '视频下载已打开。如果浏览器只是播放视频，请在新页面右键另存为。');
            } catch (error) {
                showStatus('error', error.message || '下载失败，请稍后再试。');
            }
        }

        parseBtn.addEventListener('click', parseVideo);
        videoUrl.addEventListener('keydown', event => {
            if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {
                parseVideo();
            }
        });
        resetBtn.addEventListener('click', () => {
            videoUrl.value = '';
            latestResult = null;
            resultPanel.classList.add('hidden');
            emptyPanel.classList.remove('hidden');
            statusBox.classList.add('hidden');
        });
        copySummaryBtn.addEventListener('click', () => {
            copyText((latestResult && latestResult.analysis && latestResult.analysis.summary) || '', '摘要已复制。');
        });
        copyTranscriptBtn.addEventListener('click', () => {
            copyText((latestResult && latestResult.transcript && latestResult.transcript.text) || '', '文字稿已复制。');
        });
        downloadVideoBtn.addEventListener('click', downloadVideo);
    </script>
</body>
</html>